{
    "name": "laratusk/cloudflare-tunnel",
    "description": "Start and manage Cloudflare Tunnels directly from Artisan. Supports both quick (random URL) and named (static hostname) tunnels with callback hooks.",
    "keywords": [
        "laravel",
        "cloudflare",
        "tunnel",
        "cloudflared",
        "webhook",
        "development"
    ],
    "homepage": "https://github.com/laratusk/cloudflare-tunnel",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Laratusk",
            "homepage": "https://github.com/laratusk"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "ext-pcntl": "*"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "phpstan/phpstan": "^1.0|^2.0",
        "rector/rector": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "Laratusk\\CloudflareTunnel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laratusk\\CloudflareTunnel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "analyse": "phpstan analyse --memory-limit=512M",
        "lint": "pint",
        "lint:check": "pint --test",
        "rector": "rector process",
        "rector:dry": "rector process --dry-run",
        "quality": [
            "@rector:dry",
            "@lint:check",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laratusk\\CloudflareTunnel\\CloudflareTunnelServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
